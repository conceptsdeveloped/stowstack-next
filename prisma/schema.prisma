generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ab_test_events {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  test_id    String    @db.Uuid
  variant_id String
  visitor_id String
  event_name String
  metadata   Json?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  ab_tests   ab_tests  @relation(fields: [test_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([test_id, variant_id, visitor_id, event_name], map: "idx_ab_test_events_dedup")
  @@index([test_id], map: "idx_ab_test_events_test")
}

model ab_tests {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id       String           @db.Uuid
  name              String
  description       String?
  status            String           @default("active")
  variants          Json
  metrics           Json
  landing_page_ids  String[]         @db.Uuid
  start_date        DateTime         @default(now()) @db.Timestamptz(6)
  end_date          DateTime?        @db.Timestamptz(6)
  winner_variant_id String?
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  ab_test_events    ab_test_events[]
  facilities        facilities       @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([facility_id], map: "idx_ab_tests_facility")
  @@index([status], map: "idx_ab_tests_status")
}

model activity_log {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type          String
  facility_id   String?     @db.Uuid
  lead_name     String?
  facility_name String?
  detail        String?
  meta          Json?       @default("{}")
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  facilities    facilities? @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_activity_log_created")
  @@index([facility_id], map: "idx_activity_log_facility")
}

model admin_keys {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_email      String
  key_hash        String    @unique
  key_prefix      String    @db.VarChar(8)
  label           String?
  scopes          String[]  @default(["*"])
  last_used_at    DateTime? @db.Timestamptz(6)
  expires_at      DateTime? @db.Timestamptz(6)
  revoked_at      DateTime? @db.Timestamptz(6)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)

  @@index([key_hash], map: "idx_admin_keys_hash")
  @@index([user_email], map: "idx_admin_keys_email")
}

model ad_variations {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id             String                    @db.Uuid
  brief_id                String?                   @db.Uuid
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  platform                String
  format                  String?
  angle                   String?
  content_json            Json
  asset_urls              Json?
  status                  String?                   @default("draft")
  feedback                String?
  version                 Int?                      @default(1)
  compliance_status       String?
  compliance_flags        Json?
  funnel_config           Json?
  funnel_metrics          Json?
  creative_briefs         creative_briefs?          @relation(fields: [brief_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  facilities              facilities                @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  drip_sequence_templates drip_sequence_templates[]
  publish_log             publish_log[]

  @@index([brief_id], map: "idx_variations_brief")
  @@index([facility_id], map: "idx_variations_facility")
  @@index([status], map: "idx_variations_status")
}

model api_keys {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String          @db.Uuid
  name            String
  key_hash        String          @unique
  key_prefix      String          @db.VarChar(8)
  scopes          String[]        @default([])
  rate_limit      Int?            @default(100)
  last_used_at    DateTime?       @db.Timestamptz(6)
  expires_at      DateTime?       @db.Timestamptz(6)
  revoked         Boolean?        @default(false)
  revoked_at      DateTime?       @db.Timestamptz(6)
  created_by      String?         @db.Uuid
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  organizations   organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  api_usage_log   api_usage_log[]

  @@unique([organization_id, name])
  @@index([key_hash], map: "idx_api_keys_hash")
  @@index([organization_id], map: "idx_api_keys_org")
  @@index([key_prefix], map: "idx_api_keys_prefix")
}

model api_usage_log {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  api_key_id      String    @db.Uuid
  organization_id String    @db.Uuid
  method          String
  path            String
  status_code     Int?
  duration_ms     Int?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  api_keys        api_keys      @relation(fields: [api_key_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_api_usage_created")
  @@index([api_key_id], map: "idx_api_usage_key")
  @@index([organization_id], map: "idx_api_usage_org")
}

model assets {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id String?     @db.Uuid
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  type        String
  source      String
  url         String
  metadata    Json?
  facilities  facilities? @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([facility_id], map: "idx_assets_facility")
}

model audit_report_cache {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id String     @unique @db.Uuid
  report_json Json
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  facilities  facilities @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model website_scrape_cache {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url         String      @unique
  facility_id String?     @db.Uuid
  scrape_json Json
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  facilities  facilities? @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([url], map: "idx_scrape_cache_url")
}

model audits {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id   String?     @db.Uuid
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  audit_json    Json
  overall_score Int?
  grade         String?
  facilities    facilities? @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([facility_id], map: "idx_audits_facility")
}

model betapad_notes {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id String
  entry_type String
  entry_data Json
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "idx_betapad_notes_created")
  @@index([session_id], map: "idx_betapad_notes_session")
}

model call_logs {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tracking_number_id    String                @db.Uuid
  facility_id           String                @db.Uuid
  twilio_call_sid       String                @unique
  caller_number         String?
  caller_city           String?
  caller_state          String?
  duration              Int?                  @default(0)
  status                String
  recording_url         String?
  call_outcome          String?               @db.VarChar(32)
  campaign_source       String?
  move_in_linked        Boolean               @default(false)
  started_at            DateTime              @db.Timestamptz(6)
  ended_at              DateTime?             @db.Timestamptz(6)
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  facilities            facilities            @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  call_tracking_numbers call_tracking_numbers @relation(fields: [tracking_number_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  updated_at            DateTime              @updatedAt @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "idx_call_logs_created")
  @@index([facility_id], map: "idx_call_logs_facility")
  @@index([status], map: "idx_call_logs_status")
  @@index([tracking_number_id], map: "idx_call_logs_tracking")
}

model call_tracking_numbers {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id     String         @db.Uuid
  landing_page_id String?        @db.Uuid
  utm_link_id     String?        @db.Uuid
  label           String
  twilio_sid      String         @unique
  phone_number    String
  forward_to      String
  status          String?        @default("active")
  call_count      Int?           @default(0)
  total_duration  Int?           @default(0)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  call_logs       call_logs[]
  facilities      facilities     @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  landing_pages   landing_pages? @relation(fields: [landing_page_id], references: [id], onUpdate: NoAction)
  utm_links       utm_links?     @relation(fields: [utm_link_id], references: [id], onUpdate: NoAction)

  @@index([facility_id], map: "idx_call_tracking_facility")
  @@index([phone_number], map: "idx_call_tracking_phone")
  @@index([status], map: "idx_call_tracking_status")
}

model campaign_spend {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id   String     @db.Uuid
  platform      String
  date          DateTime   @db.Date
  campaign_name String?
  campaign_id   String?
  utm_campaign  String?
  spend         Decimal    @default(0) @db.Decimal(10, 2)
  impressions   Int?       @default(0)
  clicks        Int?       @default(0)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @updatedAt @db.Timestamptz(6)
  facilities    facilities @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([facility_id, platform, campaign_id, date])
  @@index([facility_id], map: "idx_campaign_spend_facility")
  @@index([utm_campaign], map: "idx_campaign_spend_utm")
}

model churn_predictions {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String     @unique @db.Uuid
  facility_id           String     @db.Uuid
  risk_score            Int
  risk_level            String
  predicted_vacate      DateTime?  @db.Date
  factors               Json
  recommended_actions   Json?      @default("[]")
  retention_campaign_id String?    @db.Uuid
  retention_status      String?    @default("none")
  last_scored_at        DateTime?  @default(now()) @db.Timestamptz(6)
  created_at            DateTime   @default(now()) @db.Timestamptz(6)
  updated_at            DateTime   @updatedAt @db.Timestamptz(6)
  facilities            facilities           @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants               tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  retention_campaigns   retention_campaigns? @relation(fields: [retention_campaign_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([facility_id], map: "idx_churn_predictions_facility")
  @@index([risk_level], map: "idx_churn_predictions_level")
  @@index([risk_score(sort: Desc)], map: "idx_churn_predictions_risk")
}

model client_campaigns {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id        String    @db.Uuid
  month            String
  spend            Decimal   @default(0) @db.Decimal(10, 2)
  leads            Int       @default(0)
  cpl              Decimal?  @default(0) @db.Decimal(10, 2)
  move_ins         Int?      @default(0)
  cost_per_move_in Decimal?  @default(0) @db.Decimal(10, 2)
  roas             Decimal?  @default(0) @db.Decimal(6, 2)
  occupancy_delta  Decimal?  @default(0) @db.Decimal(5, 2)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  clients          clients   @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([client_id, month])
  @@index([client_id], map: "idx_client_campaigns_client")
}

model client_onboarding {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id    String    @unique @db.Uuid
  access_code  String    @db.VarChar(16)
  steps        Json      @default("{}")
  completed_at DateTime? @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  clients      clients   @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([access_code], map: "idx_client_onboarding_code")
}

model client_reports {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id    String    @db.Uuid
  facility_id  String    @db.Uuid
  report_type  String    @default("monthly") @db.VarChar(32)
  period_start DateTime  @db.Date
  period_end   DateTime  @db.Date
  report_html  String?
  report_data  Json?
  status       String    @default("generated") @db.VarChar(16)
  sent_at      DateTime? @db.Timestamptz(6)
  opened_at    DateTime? @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  clients      clients   @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  facilities   facilities @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([client_id, report_type, period_start])
  @@index([client_id], map: "idx_client_reports_client")
  @@index([facility_id], map: "idx_client_reports_facility")
  @@index([period_start, period_end], map: "idx_client_reports_period")
}

model clients {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id         String             @db.Uuid
  email               String
  name                String
  facility_name       String?
  location            String?
  occupancy_range     String?
  total_units         String?
  access_code         String             @unique @db.VarChar(16)
  monthly_goal        Int?               @default(0)
  signed_at           DateTime?          @default(now()) @db.Timestamptz(6)
  created_at          DateTime           @default(now()) @db.Timestamptz(6)
  client_campaigns    client_campaigns[]
  client_onboarding   client_onboarding?
  client_reports      client_reports[]
  facilities          facilities         @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  deleted_at          DateTime?          @db.Timestamptz(6)
  deleted_by          String?

  @@index([access_code], map: "idx_clients_access_code")
  @@index([facility_id], map: "idx_clients_facility")
  @@index([deleted_at], map: "idx_clients_deleted_at")
}

model commit_comments {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commit_hash String
  author      String
  body        String
  created_at  DateTime  @default(now()) @db.Timestamptz(6)

  @@index([commit_hash], map: "idx_commit_comments_hash")
}

model commit_enrichments {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commit_hash       String    @unique
  subject           String?
  body              String?
  dev_note          String?
  dev_name          String?
  commit_type       String?   @default("improvement")
  laymans_summary   String?
  technical_summary String?
  committed_at      DateTime? @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([commit_hash], map: "idx_commit_enrichments_hash")
}

model commit_flags {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commit_hash String
  flag_type   String
  reason      String?   @default("")
  flagged_by  String
  created_at  DateTime  @default(now()) @db.Timestamptz(6)

  @@index([commit_hash], map: "idx_commit_flags_hash")
}

model commit_reviews {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commit_hash String
  reviewed_by String
  status      String    @default("reviewed")
  created_at  DateTime  @default(now()) @db.Timestamptz(6)

  @@unique([commit_hash, reviewed_by], map: "idx_commit_reviews_unique")
}

model creative_briefs {
  id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id             String?         @db.Uuid
  created_at              DateTime        @default(now()) @db.Timestamptz(6)
  version                 Int?            @default(1)
  brief_json              Json
  platform_recommendation String[]
  status                  String?         @default("draft")
  ad_variations           ad_variations[]
  facilities              facilities?     @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([facility_id], map: "idx_briefs_facility")
}

model delinquency_escalations {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String     @db.Uuid
  facility_id      String     @db.Uuid
  stage            String
  stage_entered_at DateTime   @default(now()) @db.Timestamptz(6)
  next_stage_at    DateTime?  @db.Timestamptz(6)
  notes            String?
  automated        Boolean?   @default(true)
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  facilities       facilities @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tenants          tenants    @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([facility_id], map: "idx_delinquency_escalations_facility")
  @@index([stage], map: "idx_delinquency_escalations_stage")
  @@index([tenant_id], map: "idx_delinquency_escalations_tenant")
}

model deployment_tags {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commit_hash String
  environment String    @default("production")
  deployed_by String
  version     String?
  notes       String?
  created_at  DateTime  @default(now()) @db.Timestamptz(6)

  @@index([environment], map: "idx_deployment_tags_env")
  @@index([commit_hash], map: "idx_deployment_tags_hash")
}

model dev_handoffs {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  from_dev    String
  to_dev      String?
  title       String
  body        String
  commit_hash String?
  status      String    @default("active")
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([status], map: "idx_dev_handoffs_status")
}

model drip_sequence_templates {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id   String         @db.Uuid
  variation_id  String?        @db.Uuid
  name          String
  steps         Json
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  facilities    facilities     @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ad_variations ad_variations? @relation(fields: [variation_id], references: [id], onUpdate: NoAction)

  @@unique([facility_id, variation_id])
  @@index([facility_id], map: "idx_drip_templates_facility")
}

model drip_sequences {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facility_id   String     @unique @db.Uuid
  sequence_id   String     @default("post_audit")
  current_step  Int        @default(0)
  status        String     @default("active")
  enrolled_at   DateTime   @default(now()) @db.Timestamptz(6)
  next_send_at  DateTime?  @db.Timestamptz(6)
  paused_at     DateTime?  @db.Timestamptz(6)
  completed_at  DateTime?  @db.Timestamptz(6)
  cancelled_at  DateTime?  @db.Timestamptz(6)
  cancel_reason String?
  history       Json?      @default("[]")
  facilities    facilities @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([next_send_at], map: "idx_drip_sequences_next_send")
  @@index([status], map: "idx_drip_sequences_status")
}

model facilities {
  id                           String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                   DateTime                       @default(now()) @db.Timestamptz(6)
  name                         String
  location                     String
  contact_name                 String?
  contact_email                String?
  contact_phone                String?
  occupancy_range              String?
  total_units                  String?
  biggest_issue                String?
  notes                        String?
  place_id                     String?
  google_address               String?
  google_phone                 String?
  website                      String?
  google_rating                Decimal?                       @db.Decimal(2, 1)
  review_count                 Int?
  google_maps_url              String?
  hours                        Json?
  status                       String?                        @default("intake")
  pipeline_status              String?                        @default("submitted")
  follow_up_date               DateTime?                      @db.Date
  pms_uploaded                 Boolean?                       @default(false)
  access_code                  String?                        @unique @db.VarChar(16)
  form_notes                   String?
  lead_score                   Int?
  updated_at                   DateTime                       @updatedAt @default(now()) @db.Timestamptz(6)
  organization_id              String?                        @db.Uuid
  baseline_occupancy           Float?
  baseline_date                DateTime?                      @db.Date
  ab_tests                     ab_tests[]
  activity_log                 activity_log[]
  ad_variations                ad_variations[]
  assets                       assets[]
  audit_report_cache           audit_report_cache?
  audits                       audits[]
  call_logs                    call_logs[]
  call_tracking_numbers        call_tracking_numbers[]
  campaign_spend               campaign_spend[]
  churn_predictions            churn_predictions[]
  client_reports               client_reports[]
  clients                      clients[]
  creative_briefs              creative_briefs[]
  delinquency_escalations      delinquency_escalations[]
  drip_sequence_templates      drip_sequence_templates[]
  drip_sequences               drip_sequences?
  organizations                organizations?                 @relation(fields: [organization_id], references: [id], onUpdate: NoAction)
  facility_context             facility_context[]
  facility_market_intel        facility_market_intel?
  facility_pms_aging           facility_pms_aging[]
  facility_pms_length_of_stay  facility_pms_length_of_stay[]
  facility_pms_rate_history    facility_pms_rate_history[]
  facility_pms_rent_roll       facility_pms_rent_roll[]
